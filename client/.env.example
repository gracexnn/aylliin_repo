# ─── API ──────────────────────────────────────────────────────────────────────
# URL of the admin Next.js server (where the /api routes are hosted).
# The admin runs on :3000 by default; the client will start on :3001 when both run together.
# Server-side (Node.js) calls — can be an internal network address in production.
ADMIN_API_URL=http://localhost:3000

# Client-side (browser) calls — must be a publicly reachable URL.
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3000
