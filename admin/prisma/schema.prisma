generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id               String      @id @default(uuid()) @db.Uuid
  title            String      @db.VarChar(500)
  slug             String      @unique @db.VarChar(500)
  cover_image      String?
  excerpt          String?
  content          String?
  journey_overview String?     @db.VarChar(1000)
  package_options  Json?
  included_items   String[]    @default([])
  attraction_items String[]    @default([])
  itinerary_days   Json?
  travel_tips      String?
  published        Boolean     @default(false)
  highlighted      Boolean     @default(false)
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime    @default(now()) @updatedAt @db.Timestamptz(6)

  routes      Route[]
  post_images PostImage[]

  @@map("posts")
}

enum TransportMode {
  WALKING
  DRIVING
  CYCLING
  BUS
  TRAIN
  TRAM
  SUBWAY
  BOAT
  FERRY
  PLANE
  HELICOPTER
}

model Route {
  id         String    @id @default(uuid()) @db.Uuid
  post_id    String    @db.Uuid
  title      String    @db.VarChar(500)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  post   Post         @relation(fields: [post_id], references: [id], onDelete: Cascade)
  points RoutePoint[]

  @@index([post_id])
  @@map("routes")
}

model RoutePoint {
  id                        String   @id @default(uuid()) @db.Uuid
  route_id                  String   @db.Uuid
  order_index               Int      @default(0)
  latitude                  Float
  longitude                 Float
  name                      String   @db.VarChar(500)
  description               String?
  transport_type            TransportMode @default(WALKING)
  interesting_fact          String?
  recommended_time_to_visit String?       @db.VarChar(200)
  images                    String[]
  created_at                DateTime      @default(now()) @db.Timestamptz(6)

  route Route @relation(fields: [route_id], references: [id], onDelete: Cascade)

  @@index([route_id])
  @@index([route_id, order_index])
  @@map("route_points")
}

model PostImage {
  id         String   @id @default(uuid()) @db.Uuid
  post_id    String   @db.Uuid
  url        String
  alt        String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@map("post_images")
}
