generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id               String      @id @default(uuid()) @db.Uuid
  title            String      @db.VarChar(500)
  slug             String      @unique @db.VarChar(500)
  cover_image      String?
  excerpt          String?
  content          String?
  journey_overview String?     @db.VarChar(1000)
  package_options  Json?
  included_items   String[]    @default([])
  attraction_items String[]    @default([])
  itinerary_days   Json?
  travel_tips      String?
  published        Boolean     @default(false)
  highlighted      Boolean     @default(false)
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime    @default(now()) @updatedAt @db.Timestamptz(6)

  routes             Route[]
  post_images        PostImage[]
  departure_sessions DepartureSession[]
  bookings           Booking[]
  post_inclusions    PostInclusion[]
  post_highlights    PostHighlight[]

  @@map("posts")
}

enum TransportMode {
  WALKING
  DRIVING
  CYCLING
  BUS
  TRAIN
  TRAM
  SUBWAY
  BOAT
  FERRY
  PLANE
  HELICOPTER
}

model Route {
  id         String    @id @default(uuid()) @db.Uuid
  post_id    String    @db.Uuid
  title      String    @db.VarChar(500)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  post   Post         @relation(fields: [post_id], references: [id], onDelete: Cascade)
  points RoutePoint[]

  @@index([post_id])
  @@map("routes")
}

model RoutePoint {
  id                        String   @id @default(uuid()) @db.Uuid
  route_id                  String   @db.Uuid
  order_index               Int      @default(0)
  latitude                  Float
  longitude                 Float
  name                      String   @db.VarChar(500)
  description               String?
  transport_type            TransportMode @default(WALKING)
  interesting_fact          String?
  recommended_time_to_visit String?       @db.VarChar(200)
  images                    String[]
  day_number                Int?
  location_id               String?       @db.Uuid
  created_at                DateTime      @default(now()) @db.Timestamptz(6)

  route    Route            @relation(fields: [route_id], references: [id], onDelete: Cascade)
  location LibraryLocation? @relation(fields: [location_id], references: [id], onDelete: SetNull)

  @@index([route_id])
  @@index([route_id, order_index])
  @@map("route_points")
}

model PostImage {
  id         String   @id @default(uuid()) @db.Uuid
  post_id    String   @db.Uuid
  url        String
  alt        String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  post Post @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@map("post_images")
}

// ─── Reusable Content Library ────────────────────────────────────────────────

model LibraryInclusion {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(500)
  description String?
  icon        String?  @db.VarChar(100)
  active      Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  post_inclusions PostInclusion[]

  @@map("library_inclusions")
}

model LibraryHighlight {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(500)
  description String?
  active      Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  post_highlights PostHighlight[]

  @@map("library_highlights")
}

model LibraryLocation {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(500)
  slug              String   @unique @db.VarChar(500)
  short_description String?  @db.VarChar(1000)
  description       String?
  latitude          Float
  longitude         Float
  cover_image       String?
  gallery           String[] @default([])
  region            String?  @db.VarChar(200)
  country           String?  @db.VarChar(200)
  tags              String[] @default([])
  active            Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  route_points RoutePoint[]

  @@map("library_locations")
}

/// Join: which inclusions are assigned to a guide, in what order, with a label snapshot
model PostInclusion {
  id             String   @id @default(uuid()) @db.Uuid
  post_id        String   @db.Uuid
  inclusion_id   String   @db.Uuid
  order_index    Int      @default(0)
  label_snapshot String   @db.VarChar(500)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  post      Post             @relation(fields: [post_id], references: [id], onDelete: Cascade)
  inclusion LibraryInclusion @relation(fields: [inclusion_id], references: [id], onDelete: Cascade)

  @@unique([post_id, inclusion_id])
  @@index([post_id])
  @@map("post_inclusions")
}

/// Join: which highlights are assigned to a guide, in what order, with a label snapshot
model PostHighlight {
  id             String   @id @default(uuid()) @db.Uuid
  post_id        String   @db.Uuid
  highlight_id   String   @db.Uuid
  order_index    Int      @default(0)
  label_snapshot String   @db.VarChar(500)
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  post      Post             @relation(fields: [post_id], references: [id], onDelete: Cascade)
  highlight LibraryHighlight @relation(fields: [highlight_id], references: [id], onDelete: Cascade)

  @@unique([post_id, highlight_id])
  @@index([post_id])
  @@map("post_highlights")
}

enum SessionStatus {
  DRAFT
  OPEN
  FULL
  CANCELLED
}

enum DiscountType {
  FIXED
  PERCENT
}

model DepartureSession {
  id                String        @id @default(uuid()) @db.Uuid
  post_id           String        @db.Uuid
  package_option_id String?       @db.VarChar(100)
  departure_date    DateTime      @db.Date
  return_date       DateTime?     @db.Date
  label             String        @db.VarChar(300)
  base_price        Decimal       @db.Decimal(10, 2)
  currency          String        @default("IDR") @db.VarChar(10)
  discount_type     DiscountType?
  discount_value    Decimal?      @db.Decimal(10, 2)
  discount_reason   String?       @db.VarChar(500)
  final_price       Decimal       @db.Decimal(10, 2)
  capacity          Int           @default(0)
  seats_booked      Int           @default(0)
  status            SessionStatus @default(DRAFT)
  public_note       String?
  internal_note     String?
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  updated_at        DateTime      @default(now()) @updatedAt @db.Timestamptz(6)

  post     Post      @relation(fields: [post_id], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([post_id])
  @@index([departure_date])
  @@index([status])
  @@map("departure_sessions")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

model Booking {
  id                    String        @id @default(uuid()) @db.Uuid
  booking_code          String        @unique @db.VarChar(50)
  post_id               String        @db.Uuid
  departure_session_id  String        @db.Uuid
  package_option_id     String?       @db.VarChar(100)
  contact_name          String        @db.VarChar(300)
  contact_phone         String        @db.VarChar(50)
  contact_email         String        @db.VarChar(300)
  passenger_count       Int           @default(1)
  total_price_snapshot  Decimal       @db.Decimal(10, 2)
  currency              String        @default("IDR") @db.VarChar(10)
  booking_status        BookingStatus @default(PENDING)
  payment_status        PaymentStatus @default(UNPAID)
  admin_note            String?
  source                String        @default("admin") @db.VarChar(50)
  created_at            DateTime      @default(now()) @db.Timestamptz(6)
  updated_at            DateTime      @default(now()) @updatedAt @db.Timestamptz(6)

  post              Post             @relation(fields: [post_id], references: [id], onDelete: Cascade)
  departure_session DepartureSession @relation(fields: [departure_session_id], references: [id], onDelete: Cascade)
  travelers         Traveler[]

  @@index([post_id])
  @@index([departure_session_id])
  @@index([booking_status])
  @@index([booking_code])
  @@map("bookings")
}

model Traveler {
  id                String   @id @default(uuid()) @db.Uuid
  booking_id        String   @db.Uuid
  full_name         String   @db.VarChar(300)
  gender            String?  @db.VarChar(20)
  date_of_birth     DateTime? @db.Date
  passport_number   String?  @db.VarChar(100)
  nationality       String?  @db.VarChar(100)
  phone             String?  @db.VarChar(50)
  email             String?  @db.VarChar(300)
  emergency_contact String?  @db.VarChar(500)
  special_request   String?
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  booking Booking @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([booking_id])
  @@map("travelers")
}

model AdminUser {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(320)
  name          String    @db.VarChar(200)
  password_hash String    @db.VarChar(255)
  is_active     Boolean   @default(true)
  last_login_at DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("admin_users")
}

model SiteVisit {
  id         String   @id @db.Uuid
  visitor_id String   @db.VarChar(100)
  path       String   @db.VarChar(500)
  referrer   String?  @db.VarChar(1000)
  user_agent String?  @db.VarChar(1000)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at])
  @@index([path])
  @@index([visitor_id])
  @@map("site_visits")
}

/// Singleton table — always one row (id = '00000000-0000-0000-0000-000000000001')
model LandingPageSettings {
  id                    String   @id @db.Uuid
  hero_title            String?  @db.VarChar(500)
  hero_subtitle         String?  @db.VarChar(1000)
  hero_primary_cta_text String?  @db.VarChar(200)
  hero_primary_cta_url  String?  @db.VarChar(500)
  hero_secondary_cta_text String? @db.VarChar(200)
  hero_secondary_cta_url  String? @db.VarChar(500)
  contact_email         String?  @db.VarChar(320)
  contact_phone         String?  @db.VarChar(50)
  contact_address       String?  @db.VarChar(500)
  contact_whatsapp      String?  @db.VarChar(50)
  facebook_url          String?  @db.VarChar(500)
  instagram_url         String?  @db.VarChar(500)
  linkedin_url          String?  @db.VarChar(500)
  highlight_1_title       String?  @db.VarChar(200)
  highlight_1_description String?  @db.VarChar(500)
  highlight_2_title       String?  @db.VarChar(200)
  highlight_2_description String?  @db.VarChar(500)
  highlight_3_title       String?  @db.VarChar(200)
  highlight_3_description String?  @db.VarChar(500)
  why_label             String?  @db.VarChar(100)
  why_heading           String?  @db.VarChar(500)
  why_body              String?  @db.VarChar(1000)
  announcement_text     String?  @db.VarChar(500)
  footer_blurb          String?  @db.VarChar(500)
  meta_title            String?  @db.VarChar(200)
  meta_description      String?  @db.VarChar(500)
  og_image_url          String?  @db.VarChar(1000)
  updated_by            String?  @db.VarChar(320)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("landing_page_settings")
}
