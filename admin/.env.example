# ─────────────────────────────────────────────────────────────────────────────
#  ADMIN — ENVIRONMENT VARIABLES
#
#  Copy this file to .env.local (development) or set these in your hosting
#  platform (production) for EACH tenant deployment.
#
#  Every tenant gets a completely isolated database — all you need is a
#  different DATABASE_URL per deployment.  Nothing else needs to change.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Each tenant MUST point to its own PostgreSQL database.
# This is the only thing you need to change to give an agency a fully isolated
# database — Prisma reads this at runtime.
#
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://user:password@localhost:5432/aylal_db

# ─── App URLs ─────────────────────────────────────────────────────────────────
# Public URL of this admin deployment (used for absolute links, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Allowed origin for the public client app (used in CORS headers on API routes)
CLIENT_ORIGIN=http://localhost:3001

# ─── Authentication ───────────────────────────────────────────────────────────
# Random secret for signing NextAuth JWTs.  Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret-value

# ─── File Storage (Cloudflare R2 / S3-compatible) ─────────────────────────────
# Each tenant can share a bucket (using a folder prefix) or have its own bucket.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
# Public base URL of the bucket (e.g. https://pub-xxxx.r2.dev or custom domain)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ─── Payments (QPay) ──────────────────────────────────────────────────────────
QPAY_ENDPOINT=https://merchant.qpay.mn/v2
QPAY_USERNAME=your-qpay-username
QPAY_PASSWORD=your-qpay-password
QPAY_MERCHANT_ID=your-merchant-id
QPAY_INVOICE_CODE=your-invoice-code
# Publicly reachable URL that QPay will POST payment callbacks to
QPAY_CALLBACK=https://your-domain.com/api/public/payments/callback

# ─── Admin user seeding (scripts only) ───────────────────────────────────────
# Used by:  npm run auth:seed-admin
# Set these once when bootstrapping a new tenant's database, then remove them.
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-immediately
ADMIN_SEED_NAME=Admin

# ─── Stale booking cleanup ────────────────────────────────────────────────────
# Secret token required in the Authorization: Bearer <token> header when calling
#   POST /api/admin/stale-bookings/cleanup
# Generate one with: openssl rand -base64 32
CLEANUP_SECRET=replace-with-a-random-secret-value

# How many hours before an unpaid PENDING booking is considered stale (default: 24)
STALE_BOOKING_HOURS=24
